{
  "name": "matrix-dash",
  "version": "0.1.0",
  "description": "Matrix Dashboard — a local-first AI command center. Multi-provider chat, a real on-disk IDE, autonomous agents, and an integrated site builder, self-hosted on your own machine.",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZachBoyd1912/matrix-dash.git"
  },
  "homepage": "https://matrix.zbautomations.ie",
  "author": "ZachBoyd1912",
  "keywords": [
    "ai",
    "dashboard",
    "local-first",
    "self-hosted",
    "nextjs",
    "matrix"
  ],
  "private": true,
  "scripts": {
    "predev": "rm -rf .next",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky || exit 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
